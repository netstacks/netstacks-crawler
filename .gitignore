/.claude/
/Context
*.bak
/plan*.md

# -- macOS / cross-platform --
.DS_Store
Thumbs.db

# -- Playwright MCP working dir + ad-hoc dev screenshots at repo root --
/.playwright-mcp/
/*.png

# -- Allow docker hooks dir which would otherwise be hidden by other rules --
!.docker/hooks/*

# Local dev compose override (bind-mounts source for fast Perl iteration)
docker-compose.override.yml
