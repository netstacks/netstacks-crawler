Build
_build/
blib/
MYMETA.*
MANIFEST.*
Makefile*
*.tar.gz
*.swp
*.pid
test.pl

# -- Editor / IDE --
.idea/
.vscode/
*.komodo*
.stylelintrc

# -- Python --
*__pycache__*
.ruff_cache/
uv.lock

# -- Node / web-ui --
node_modules/
yarn.lock
web-ui/src/**/*.js
web-ui/*.tsbuildinfo
web-ui/dist/
web-ui/test-results/
web-ui/playwright-report/
web-ui/.vite/

# -- Built SPA artifacts (baked into docker image at build time) --
share/public/ui/

# -- Runtime / dev artifacts --
.env
/deployment.yml
/package-lock.json
.netstacks/
.superpowers/
